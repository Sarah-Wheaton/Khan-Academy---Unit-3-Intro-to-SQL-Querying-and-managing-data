--> Actors: Full name and typical genre

SELECT fullname, typical_genre FROM actors


--> Actors and singers: Net worth >= 20 million
SELECT fullname, net_worth, "Actor" AS industry FROM actors
    WHERE net_worth >= 20
    
UNION ALL

SELECT fullname, net_worth, "Singer" AS industry FROM singers
    WHERE net_worth >= 20
    ORDER BY net_worth DESC;


--> Actors and singers: Nationality
SELECT fullname, nationality FROM actors 

UNION ALL

SELECT fullname, nationality FROM singers
    ORDER BY nationality ASC;


--> Actors and singers: age >= 30
SELECT fullname, age FROM actors
    WHERE birthday >= 30

UNION ALL

SELECT fullname, age FROM singers
    WHERE age >= 30
    ORDER BY age ASC;



--> Actors: nationality American AND net worth > 25 million

SELECT * FROM actors WHERE nationality = "American" AND net_worth > 25;
 

--> Actors, age and movies title JOIN

/* explicit inner join - JOIN */
SELECT actors.fullname, actors.age, movies.title
    FROM actors
    JOIN movies
    ON actors.id = movies.actor_id;


--> Actors name, age, movie title where typical genre is Drama

/* explicit inner join - JOIN */
SELECT actors.fullname, actors.age, actors.typical_genre, movies.title
    FROM actors
    JOIN movies
    ON actors.id = movies.actor_id
    WHERE actors.typical_genre = "Drama";
